# OpenAI / Anthropic keys (loaded into the Spring app via spring-dotenv)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Postgres / pgvector - used by docker-compose AND the Spring App's application.properties
DB_HOST=localhost
DB_NAME=corpusai
DB_USER=postgres
DB_PASSWORD=postgres

# JWT auth (HMAC-SHA256 signing secret, must be at least 32 bytes; generate with `openssl rand -base64 48`)
JWT_SECRET=
JWT_EXPIRATION_HOURS=24

# Seed admin - created on first boot if a user with this email doesn't already exist
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Document storage root (subject documents live at {STORAGE_ROOT}/{subjectId}/{fileName})
STORAGE_ROOT=./storage/documents
